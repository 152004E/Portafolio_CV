---
interface Stat {
  number: string;
  description: string;
  highlight?: boolean;
}

interface Props {
  stats?: Stat[];
}

const defaultStats: Stat[] = [
  { number: "15+", description: "Proyectos desarrollados para clientes locales y startups digitales", highlight: true },
  { number: "3", description: "Años de experiencia en diseño y desarrollo web" },
  { number: "6", description: "Proyectos integrando frontend, backend y bases de datos" },
  { number: "2+", description: "Aplicaciones diseñadas con enfoque en usabilidad y rendimiento" },
];

const { stats = defaultStats } = Astro.props;
---

<div class="relative w-full max-w-[1100px] mx-auto mt-12 lg:mt-16">
  <div class="bg-[#0a0a0f]/80 backdrop-blur-md border border-blue-500/20 p-5 md:p-6 rounded-[2rem] shadow-2xl shadow-blue-500/5">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      {stats.map((stat) => (
        <div
          class={`p-4 md:p-5 rounded-2xl text-left transition-all duration-300 hover:scale-[1.03] ${
            stat.highlight
              ? "bg-gradient-to-br from-blue-600 to-blue-800 text-white shadow-lg shadow-blue-500/20"
              : "bg-white/5 border border-white/5 hover:border-blue-500/30"
          }`}
        >
          <h3 class={`text-3xl md:text-4xl font-extrabold mb-1 ${stat.highlight ? "text-white" : "text-blue-400"}`}>
            {stat.number}
          </h3>
          <p class="text-sm font-medium leading-snug opacity-80">
            {stat.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</div>
