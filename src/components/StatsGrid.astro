---
interface Stat {
  number: string;
  description: string;
  icon: string;
  highlight?: boolean;
}

interface Props {
  stats?: Stat[];
}

const defaultStats: Stat[] = [
  { number: "15+", description: "Proyectos desarrollados para clientes locales y startups digitales", icon: "fa-solid fa-rocket", highlight: true },
  { number: "3", description: "Años de experiencia en diseño y desarrollo web", icon: "fa-solid fa-code" },
  { number: "6", description: "Proyectos integrando frontend, backend y bases de datos", icon: "fa-solid fa-layer-group" },
  { number: "2+", description: "Aplicaciones diseñadas con enfoque en usabilidad y rendimiento", icon: "fa-solid fa-gauge-high" },
];

const { stats = defaultStats } = Astro.props;
---

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
  {stats.map((stat) => (
    <div
      class={`group relative overflow-hidden rounded-2xl p-5 md:p-6 transition-all duration-300 hover:-translate-y-1 hover:scale-[1.02] ${
        stat.highlight
          ? "bg-gradient-to-br from-blue-600/90 to-blue-800/90 border border-blue-500/30 shadow-lg shadow-blue-500/15"
          : "border border-gray-200/60 dark:border-white/10 bg-gray-50 dark:bg-white/[0.03] backdrop-blur-md hover:border-blue-500/40 hover:shadow-[0_0_20px_rgba(59,130,246,0.1)]"
      }`}
    >
      <div class="flex items-start gap-4">
        <div class={`flex h-10 w-10 shrink-0 items-center justify-center rounded-xl text-lg ${
          stat.highlight
            ? "bg-white/15 text-white"
            : "bg-blue-500/10 text-blue-400"
        }`}>
          <i class={stat.icon}></i>
        </div>
        <div>
          <h3 class={`text-2xl md:text-3xl font-extrabold tracking-tight ${
            stat.highlight ? "text-white" : "text-blue-400"
          }`}>
            {stat.number}
          </h3>
          <p class="text-xs md:text-sm font-medium leading-relaxed mt-1 opacity-80 text-gray-500 dark:text-gray-300">
            {stat.description}
          </p>
        </div>
      </div>
    </div>
  ))}
</div>
