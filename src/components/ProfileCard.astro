---
interface Props {
  imageSrc?: string;
  alt?: string;
}

const { imageSrc = "/images/imagenparagithudoptimazadaOP.png", alt = "Emerson Reyes" } = Astro.props;
---

<div class="relative flex items-center justify-center w-[280px] h-[280px] sm:w-[320px] sm:h-[320px] md:w-[380px] md:h-[380px]">
  <!-- Glow base -->
  <div class="absolute inset-0 rounded-full bg-gradient-to-r from-blue-500/15 via-cyan-500/10 to-blue-500/15 blur-3xl animate-glow-pulse"></div>

  <!-- Orbital ring 1 - outer, slow -->
  <div class="absolute inset-0 rounded-full animate-orbit-slow">
    <div class="absolute inset-0 rounded-full border border-blue-400/15"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 w-2 h-2 rounded-full bg-blue-400/40 blur-[2px]"></div>
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 translate-y-1/2 w-1.5 h-1.5 rounded-full bg-cyan-400/30 blur-[1px]"></div>
    <div class="absolute left-0 top-1/2 -translate-x-1/2 -translate-y-1/2 w-1.5 h-1.5 rounded-full bg-blue-400/30 blur-[1px]"></div>
    <div class="absolute right-0 top-1/2 translate-x-1/2 -translate-y-1/2 w-2 h-2 rounded-full bg-cyan-400/40 blur-[2px]"></div>
  </div>

  <!-- Orbital ring 2 - medium, reverse -->
  <div class="absolute inset-2 rounded-full animate-orbit-reverse">
    <div class="absolute inset-0 rounded-full border border-blue-400/10 border-dashed"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 w-1 h-1 rounded-full bg-blue-300/50 blur-[1px]"></div>
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 translate-y-1/2 w-1 h-1 rounded-full bg-cyan-300/50 blur-[1px]"></div>
  </div>

  <!-- Orbital ring 3 - inner arcs -->
  <div class="absolute inset-4 rounded-full animate-orbit-medium">
    <svg class="w-full h-full" viewBox="0 0 100 100" fill="none">
      <circle cx="50" cy="50" r="48" stroke="url(#arcGrad)" stroke-width="0.5" stroke-dasharray="25 8 10 8" class="opacity-30" />
      <defs>
        <linearGradient id="arcGrad" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="#3b82f6" stop-opacity="0" />
          <stop offset="30%" stop-color="#3b82f6" stop-opacity="0.3" />
          <stop offset="50%" stop-color="#06b6d4" stop-opacity="0.4" />
          <stop offset="70%" stop-color="#3b82f6" stop-opacity="0.3" />
          <stop offset="100%" stop-color="#3b82f6" stop-opacity="0" />
        </linearGradient>
      </defs>
    </svg>
  </div>

  <!-- Particles -->
  <div class="absolute inset-0 rounded-full">
    <div class="absolute top-[10%] left-[15%] w-1 h-1 rounded-full bg-blue-400/60 animate-particle-1"></div>
    <div class="absolute top-[20%] right-[18%] w-0.5 h-0.5 rounded-full bg-cyan-400/50 animate-particle-2"></div>
    <div class="absolute top-[65%] left-[8%] w-0.5 h-0.5 rounded-full bg-blue-300/40 animate-particle-3"></div>
    <div class="absolute bottom-[15%] right-[12%] w-1 h-1 rounded-full bg-cyan-300/50 animate-particle-4"></div>
    <div class="absolute top-[45%] right-[6%] w-0.5 h-0.5 rounded-full bg-blue-400/40 animate-particle-1"></div>
    <div class="absolute bottom-[30%] left-[10%] w-0.5 h-0.5 rounded-full bg-cyan-400/40 animate-particle-2"></div>
    <div class="absolute top-[80%] left-[60%] w-0.5 h-0.5 rounded-full bg-blue-300/50 animate-particle-3"></div>
    <div class="absolute top-[30%] left-[70%] w-1 h-1 rounded-full bg-cyan-300/40 animate-particle-4"></div>
  </div>

  <!-- HUD corner brackets -->
  <div class="absolute -inset-3 opacity-30">
    <svg class="w-full h-full" viewBox="0 0 100 100" fill="none">
      <path d="M5 35 L5 5 L35 5" stroke="#3b82f6" stroke-width="0.8" class="animate-pulse-slow" />
      <path d="M95 35 L95 5 L65 5" stroke="#06b6d4" stroke-width="0.8" class="animate-pulse-slow" style="animation-delay: 1s" />
      <path d="M5 65 L5 95 L35 95" stroke="#3b82f6" stroke-width="0.8" class="animate-pulse-slow" style="animation-delay: 2s" />
      <path d="M95 65 L95 95 L65 95" stroke="#06b6d4" stroke-width="0.8" class="animate-pulse-slow" style="animation-delay: 3s" />
    </svg>
  </div>

  <!-- HUD scanning line -->
  <div class="absolute inset-0 rounded-full overflow-hidden opacity-[0.04]">
    <div class="w-full h-px bg-gradient-to-r from-transparent via-blue-400 to-transparent animate-scan"></div>
  </div>

  <!-- Profile image container -->
  <div class="relative w-[220px] h-[220px] sm:w-[250px] sm:h-[250px] md:w-[300px] md:h-[300px] rounded-full bg-gradient-to-b from-blue-200/50 via-blue-100/30 to-white dark:from-blue-600/30 dark:via-blue-800/10 dark:to-blue-900/30 border border-blue-400/20 flex items-center justify-center shadow-2xl shadow-blue-500/10 z-10">
    <div class="absolute inset-0 rounded-full bg-[radial-gradient(ellipse_at_center,rgba(59,130,246,0.1)_0%,transparent_70%)]"></div>
    <img
      class="w-full max-w-[80%] object-contain z-10 relative"
      src={imageSrc}
      alt={alt}
      loading="eager"
    />
  </div>
</div>

<style>
  @keyframes orbit-slow {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  @keyframes orbit-reverse {
    from { transform: rotate(360deg); }
    to { transform: rotate(0deg); }
  }
  @keyframes orbit-medium {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  @keyframes glow-pulse {
    0%, 100% { opacity: 0.6; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.05); }
  }
  @keyframes particle-1 {
    0%, 100% { opacity: 0.2; transform: translate(0, 0); }
    25% { opacity: 0.8; transform: translate(3px, -3px); }
    50% { opacity: 0.3; transform: translate(-2px, 2px); }
    75% { opacity: 0.7; transform: translate(2px, -1px); }
  }
  @keyframes particle-2 {
    0%, 100% { opacity: 0.3; transform: translate(0, 0); }
    25% { opacity: 0.7; transform: translate(-2px, 3px); }
    50% { opacity: 0.2; transform: translate(3px, -2px); }
    75% { opacity: 0.9; transform: translate(-1px, 2px); }
  }
  @keyframes particle-3 {
    0%, 100% { opacity: 0.4; transform: translate(0, 0); }
    33% { opacity: 0.9; transform: translate(2px, 2px); }
    66% { opacity: 0.2; transform: translate(-3px, -1px); }
  }
  @keyframes particle-4 {
    0%, 100% { opacity: 0.2; transform: translate(0, 0); }
    33% { opacity: 0.6; transform: translate(-3px, -2px); }
    66% { opacity: 0.8; transform: translate(2px, 3px); }
  }
  @keyframes pulse-slow {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 0.7; }
  }
  @keyframes scan {
    0% { top: -2%; }
    100% { top: 102%; }
  }

  .animate-orbit-slow {
    animation: orbit-slow 20s linear infinite;
  }
  .animate-orbit-reverse {
    animation: orbit-reverse 16s linear infinite;
  }
  .animate-orbit-medium {
    animation: orbit-medium 12s linear infinite;
  }
  .animate-glow-pulse {
    animation: glow-pulse 4s ease-in-out infinite;
  }
  .animate-particle-1 {
    animation: particle-1 5s ease-in-out infinite;
  }
  .animate-particle-2 {
    animation: particle-2 6s ease-in-out infinite;
  }
  .animate-particle-3 {
    animation: particle-3 4s ease-in-out infinite;
  }
  .animate-particle-4 {
    animation: particle-4 7s ease-in-out infinite;
  }
  .animate-pulse-slow {
    animation: pulse-slow 3s ease-in-out infinite;
  }
  .animate-scan {
    animation: scan 6s linear infinite;
  }
</style>
