---
---
<section id="tecnologias" class="py-12">
  <div class="container mx-auto px-4">
    <h3 class="font-bold text-white text-center uppercase text-3xl md:text-4xl tracking-wider mb-12">
      Soluciones digitales
    </h3>
    
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center max-w-[1200px] mx-auto">
      <!-- Left Column: Illustration -->
      <div class="flex justify-center">
        <img
          src="/images/ux-uiOP.webp"
          class="max-h-[450px] object-contain animate__animated animate__fadeIn"
          alt="Ilustracion UX/UI"
        />
      </div>
      
      <!-- Right Column: Articles -->
      <div class="flex flex-col gap-4">
        <!-- Primer artículo: UX Research -->
        <article
          class="bg-zinc-950/45 hover:bg-zinc-900/60 border border-zinc-800 hover:border-blue-500/50 rounded-2xl p-6 text-center shadow-lg transition duration-300 transform hover:-translate-y-1"
          data-aos="fade-right"
        >
          <div class="text-blue-500 text-3xl mb-3">
            <i class="fa-solid fa-magnifying-glass"></i>
          </div>
          <h4 class="text-blue-400 text-xl font-bold mb-2">
            UX Research
          </h4>
          <p class="text-gray-300 text-sm md:text-base leading-relaxed">
            Investigación centrada en usuarios para entender sus
            necesidades, hábitos y comportamientos antes de diseñar una
            solución efectiva.
          </p>
        </article>

        <!-- Segundo artículo: UX/UI Design -->
        <article
          class="bg-blue-600 border border-blue-500 rounded-2xl p-6 text-center shadow-xl transition duration-300 transform hover:-translate-y-1 text-white"
          data-aos="fade-left"
        >
          <div class="text-white text-3xl mb-3">
            <i class="fa-solid fa-bezier-curve"></i>
          </div>
          <h4 class="text-white text-xl font-bold mb-2">
            UX/UI Design
          </h4>
          <p class="text-blue-50 text-sm md:text-base leading-relaxed">
            Diseño de interfaces atractivas y funcionales que mejoran la
            experiencia del usuario, combinando estética y usabilidad en
            cada pantalla.
          </p>
        </article>

        <!-- Tercer artículo: Prototipado -->
        <article
          class="bg-zinc-950/45 hover:bg-zinc-900/60 border border-zinc-800 hover:border-blue-500/50 rounded-2xl p-6 text-center shadow-lg transition duration-300 transform hover:-translate-y-1"
          data-aos="fade-right"
        >
          <div class="text-blue-500 text-3xl mb-3">
            <i class="fa-solid fa-table-columns"></i>
          </div>
          <h4 class="text-blue-400 text-xl font-bold mb-2">
            Prototipado
          </h4>
          <p class="text-gray-300 text-sm md:text-base leading-relaxed">
            Conocimientos en análisis de datos y aplicación de métodos cualitativos para optimizar la experiencia del usuario al interactuar con el producto.
          </p>
        </article>
      </div>
    </div>
  </div>
</section>
<div class="container mx-auto my-12 border-b border-blue-500/10 max-w-[1200px]"></div>
