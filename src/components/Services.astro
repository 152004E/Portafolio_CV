---
import TechCard from './TechCard.astro';

const categories = [
  {
    title: "Frontend",
    icon: "fa-solid fa-display",
    technologies: [
      { name: "React", level: "Intermedio", icon: "fa-brands fa-react", description: "Componentes funcionales, hooks, estado global, React Router." },
      { name: "TypeScript", level: "Intermedio", icon: "fa-brands fa-js", description: "Tipado estático, interfaces, genéricos, tipos avanzados." },
      { name: "JavaScript", level: "Intermedio", icon: "fa-brands fa-js", description: "ES6+, asincronía, manipulación del DOM, fetch API." },
      { name: "TailwindCSS", level: "Avanzado", icon: "fa-brands fa-css3-alt", description: "Diseño utility-first, responsive, custom config, animaciones." },
      { name: "Bootstrap", level: "Avanzado", icon: "fa-brands fa-bootstrap", description: "Grid system, componentes, personalización de temas." },
      { name: "HTML & CSS", level: "Avanzado", icon: "fa-brands fa-html5", description: "Semántica web, flexbox, grid, animaciones CSS, SASS." },
    ],
  },
  {
    title: "Backend",
    icon: "fa-solid fa-server",
    technologies: [
      { name: "Java", level: "Intermedio", icon: "fa-brands fa-java", description: "POO, colecciones, streams, manejo de excepciones, JDBC." },
      { name: "Spring Boot", level: "Intermedio", icon: "fa-solid fa-leaf", description: "REST APIs, JPA, seguridad, inyección de dependencias." },
      { name: "Node.js", level: "Intermedio", icon: "fa-brands fa-node-js", description: "Express, APIs REST, manejo de paquetes, npm." },
      { name: "PHP", level: "Básico", icon: "fa-brands fa-php", description: "Lógica del lado del servidor, conexión a bases de datos." },
    ],
  },
  {
    title: "Bases de Datos",
    icon: "fa-solid fa-database",
    technologies: [
      { name: "PostgreSQL", level: "Intermedio", icon: "fa-solid fa-database", description: "Consultas SQL, joins, índices, normalización de datos." },
      { name: "MySQL", level: "Intermedio", icon: "fa-solid fa-database", description: "Diseño relacional, procedimientos almacenados, optimización." },
    ],
  },
  {
    title: "Herramientas",
    icon: "fa-solid fa-tools",
    technologies: [
      { name: "Git & GitHub", level: "Intermedio", icon: "fa-brands fa-git-alt", description: "Control de versiones, ramas, pull requests, flujo colaborativo." },
      { name: "Docker", level: "Básico", icon: "fa-brands fa-docker", description: "Contenedores, imágenes, docker-compose, entornos aislados." },
      { name: "Linux", level: "Intermedio", icon: "fa-brands fa-linux", description: "Terminal, comandos, permisos, scripts bash, servidores." },
      { name: "Claude Code", level: "Básico", icon: "fa-solid fa-robot", description: "Asistente de codificación con IA para desarrollo asistido." },
      { name: "OpenCode", level: "Básico", icon: "fa-solid fa-terminal", description: "CLI interactivo para ingeniería de software con IA." },
      { name: "Ollama", level: "Básico", icon: "fa-solid fa-brain", description: "Ejecución local de modelos de lenguaje para desarrollo." },
    ],
  },
];

function getLevelColor(level: string) {
  if (level === "Avanzado") return "bg-emerald-500/15 text-emerald-400 border-emerald-500/25";
  if (level === "Intermedio") return "bg-blue-500/15 text-blue-400 border-blue-500/25";
  return "bg-yellow-500/15 text-yellow-400 border-yellow-500/25";
}
---

<section id="tecnologias" class="relative py-20 md:py-28 overflow-hidden">
  <div class="container mx-auto px-4 relative z-10">
    <div class="text-center mb-14" data-aos="fade-up">
      <span class="inline-block bg-blue-500/20 text-blue-400 px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider mb-4">
        Skills
      </span>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 dark:text-white leading-tight">
        Stack <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-blue-300 to-cyan-400">Principal</span>
      </h2>
      <p class="text-gray-500 mt-3 text-sm md:text-base max-w-xl mx-auto">
        Tecnologías con las que trabajo día a día para construir soluciones completas y escalables.
      </p>
    </div>

    <div class="relative grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-0">
      <!-- Vertical Divider -->
      <div class="hidden lg:block absolute left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-blue-500/20 via-blue-400/10 to-transparent -translate-x-1/2"></div>

      <!-- Left Column: Backend + Tools -->
      <div class="flex flex-col gap-10 lg:pr-8">
        <div data-aos="fade-up" data-aos-delay="100">
          <div class="flex items-center gap-3 mb-5">
            <div class="flex items-center gap-2 px-4 py-2 rounded-full bg-gray-100 dark:bg-white/[0.03] border border-gray-200/60 dark:border-white/10">
              <i class="fa-solid fa-server text-blue-400 text-sm"></i>
              <h3 class="text-gray-800 dark:text-white font-semibold text-lg">Backend</h3>
            </div>
            <div class="flex-1 h-px bg-gradient-to-r from-blue-500/20 to-transparent"></div>
          </div>
          <div class="grid grid-cols-1 gap-3">
            {categories[1].technologies.map((tech) => (
              <TechCard icon={tech.icon} name={tech.name} level={tech.level} description={tech.description} />
            ))}
          </div>
        </div>

        <div data-aos="fade-up" data-aos-delay="300">
          <div class="flex items-center gap-3 mb-5">
            <div class="flex items-center gap-2 px-4 py-2 rounded-full bg-gray-100 dark:bg-white/[0.03] border border-gray-200/60 dark:border-white/10">
              <i class="fa-solid fa-tools text-blue-400 text-sm"></i>
              <h3 class="text-gray-800 dark:text-white font-semibold text-lg">Herramientas</h3>
            </div>
            <div class="flex-1 h-px bg-gradient-to-r from-blue-500/20 to-transparent"></div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {categories[3].technologies.map((tech) => (
              <TechCard icon={tech.icon} name={tech.name} level={tech.level} description={tech.description} />
            ))}
          </div>
        </div>
      </div>

      <!-- Right Column: Frontend + Databases -->
      <div class="flex flex-col gap-10 lg:pl-8">
        <div data-aos="fade-up">
          <div class="flex items-center gap-3 mb-5">
            <div class="flex items-center gap-2 px-4 py-2 rounded-full bg-gray-100 dark:bg-white/[0.03] border border-gray-200/60 dark:border-white/10">
              <i class="fa-solid fa-display text-blue-400 text-sm"></i>
              <h3 class="text-gray-800 dark:text-white font-semibold text-lg">Frontend</h3>
            </div>
            <div class="flex-1 h-px bg-gradient-to-r from-blue-500/20 to-transparent"></div>
          </div>
          <div class="grid grid-cols-1 gap-3">
            {categories[0].technologies.map((tech) => (
              <TechCard icon={tech.icon} name={tech.name} level={tech.level} description={tech.description} />
            ))}
          </div>
        </div>

        <div data-aos="fade-up" data-aos-delay="200">
          <div class="flex items-center gap-3 mb-5">
            <div class="flex items-center gap-2 px-4 py-2 rounded-full bg-gray-100 dark:bg-white/[0.03] border border-gray-200/60 dark:border-white/10">
              <i class="fa-solid fa-database text-blue-400 text-sm"></i>
              <h3 class="text-gray-800 dark:text-white font-semibold text-lg">Bases de Datos</h3>
            </div>
            <div class="flex-1 h-px bg-gradient-to-r from-blue-500/20 to-transparent"></div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {categories[2].technologies.map((tech) => (
              <TechCard icon={tech.icon} name={tech.name} level={tech.level} description={tech.description} />
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
