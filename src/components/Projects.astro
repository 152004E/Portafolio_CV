---
---
<section class="section-proyectos py-12" id="section-proyectos">
  <div class="container mx-auto px-4">
    <h3 class="font-bold text-white text-center uppercase text-3xl md:text-4xl tracking-wider mb-12">
      Últimos Proyectos
    </h3>
    
    <div class="flex flex-col gap-8 max-w-[1100px] mx-auto">
      <!-- project 1: Huerta Directa -->
      <div
        class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center border border-white/10 p-6 md:p-8 rounded-3xl blur-bg shadow-2xl"
        data-aos="fade-right"
      >
        <div class="order-2 lg:order-1 text-left">
          <span class="bg-blue-500/20 text-blue-400 px-3 py-1 rounded-full text-xs font-semibold uppercase tracking-wider">
            Web App
          </span>
          <h3 class="text-blue-400 font-bold text-2xl md:text-3xl mt-3">
            HuertaDirecta
          </h3>
          <p class="text-gray-300 mt-3 text-sm md:text-base leading-relaxed">
            HuertaDirecta es una plataforma web que conecta a campesinos
            colombianos con compradores, facilitando la venta directa de
            productos agrícolas frescos de forma simple, rápida y justa.
          </p>
          <a
            href="https://github.com/152004E/web-huerta-directa"
            target="_blank"
            class="inline-block bg-blue-600 hover:bg-blue-700 text-white font-semibold px-5 py-2.5 rounded-full mt-4 transition duration-300 shadow-md"
          >
            Ver en GitHub <i class="fa-brands fa-github ml-1"></i>
          </a>
        </div>
        <div class="order-1 lg:order-2 flex justify-center">
          <img
            src="/images/proyecto-1OP.webp"
            alt="Huerta Directa"
            class="rounded-2xl w-full h-auto object-cover max-h-[280px] shadow-lg border border-white/5"
          />
        </div>
      </div>

      <!-- project 2: SENA Portfolio -->
      <div
        class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center border border-white/10 p-6 md:p-8 rounded-3xl blur-bg shadow-2xl"
        data-aos="fade-left"
      >
        <div class="order-2 text-left">
          <span class="bg-blue-500/20 text-blue-400 px-3 py-1 rounded-full text-xs font-semibold uppercase tracking-wider">
            Portafolio
          </span>
          <h3 class="text-blue-400 font-bold text-2xl md:text-3xl mt-3">
            SENA Portfolio
          </h3>
          <p class="text-gray-300 mt-3 text-sm md:text-base leading-relaxed">
            Proyectos desarrollados en el SENA que demuestran mis
            habilidades y competencias técnicas en desarrollo web y
            programación.
          </p>
          <a
            href="https://github.com/152004E/SENA-Portfolio"
            target="_blank"
            class="inline-block bg-blue-600 hover:bg-blue-700 text-white font-semibold px-5 py-2.5 rounded-full mt-4 transition duration-300 shadow-md"
          >
            Ver en GitHub <i class="fa-brands fa-github ml-1"></i>
          </a>
        </div>
        <div class="order-1 flex justify-center">
          <img
            src="/images/proyecto-2OP.webp"
            alt="SENA Portfolio"
            class="rounded-2xl w-full h-auto object-cover max-h-[280px] shadow-lg border border-white/5"
          />
        </div>
      </div>

      <!-- project 3: Personal Projects -->
      <div
        class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center border border-white/10 p-6 md:p-8 rounded-3xl blur-bg shadow-2xl"
        data-aos="fade-right"
      >
        <div class="order-2 lg:order-1 text-left">
          <span class="bg-blue-500/20 text-blue-400 px-3 py-1 rounded-full text-xs font-semibold uppercase tracking-wider">
            Proyectos
          </span>
          <h3 class="text-blue-400 font-bold text-2xl md:text-3xl mt-3">
            Personal Projects
          </h3>
          <p class="text-gray-300 mt-3 text-sm md:text-base leading-relaxed">
            Estos proyectos reflejan mi aprendizaje y pasión por el
            desarrollo de software. Me han permitido fortalecer
            habilidades en programación, bases de datos y resolución de
            problemas.
          </p>
          <a
            href="https://github.com/152004E/Personal-projects"
            target="_blank"
            class="inline-block bg-blue-600 hover:bg-blue-700 text-white font-semibold px-5 py-2.5 rounded-full mt-4 transition duration-300 shadow-md"
          >
            Ver en GitHub <i class="fa-brands fa-github ml-1"></i>
          </a>
        </div>
        <div class="order-1 lg:order-2 flex justify-center">
          <img
            src="/images/proyecto-3-optimizadaOP.png"
            alt="Proyectos personales"
            class="rounded-2xl w-full h-auto object-cover max-h-[280px] shadow-lg border border-white/5"
          />
        </div>
      </div>
    </div>
  </div>
</section>
<div class="container mx-auto my-12 border-b border-blue-500/10 max-w-[1200px]"></div>
