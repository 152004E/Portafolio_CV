---
interface Project {
  id: string;
  name: string;
  category: string;
  description: string;
  stack: { name: string; icon: string; color: string; }[];
  status: string;
  statusColor: string;
  statusBg: string;
  image: string;
  imageLabel?: string;
  links: { label: string; url?: string; primary?: boolean; }[];
}

const projects: Project[] = [
  {
    id: "room911",
    name: "ROOM 911",
    category: "Enterprise Security",
    description: "Sistema empresarial de control de acceso biométrico con JWT, dashboards en tiempo real y gestión de empleados. Implementa detección de anomalías y registro de entrada/salida.",
    stack: [
      { name: "Spring Boot", icon: "fa-solid fa-leaf", color: "text-green-500" },
      { name: "React", icon: "fa-brands fa-react", color: "text-cyan-400" },
      { name: "PostgreSQL", icon: "fa-solid fa-database", color: "text-blue-400" },
    ],
    status: "Production",
    statusColor: "text-emerald-400",
    statusBg: "bg-emerald-500/10 border-emerald-500/20",
    image: "",
    imageLabel: "Enterprise Security",
    links: [
      { label: "Live Demo", primary: true },
      { label: "GitHub", icon: "fa-brands fa-github" },
    ],
  },
  {
    id: "huertadirecta",
    name: "HuertaDirecta",
    category: "Agri-tech",
    description: "Plataforma web que conecta campesinos colombianos con compradores, facilitando la venta directa de productos agrícolas frescos con inventario en tiempo real.",
    stack: [
      { name: "React", icon: "fa-brands fa-react", color: "text-cyan-400" },
      { name: "Tailwind", icon: "fa-brands fa-css3-alt", color: "text-blue-400" },
      { name: "Node.js", icon: "fa-brands fa-node-js", color: "text-green-500" },
    ],
    status: "Completed",
    statusColor: "text-gray-400",
    statusBg: "bg-white/5 border-white/10",
    image: "",
    imageLabel: "Agri-tech",
    links: [
      { label: "GitHub", url: "https://github.com/152004E/web-huerta-directa", icon: "fa-brands fa-github" },
    ],
  },
  {
    id: "algotrainer",
    name: "AlgoTrainer",
    category: "Utility / Gaming",
    description: "Plataforma interactiva para speedcubers enfocada en reconocimiento de patrones, entrenamiento de algoritmos y optimización de finger tricks con visualizaciones 3D.",
    stack: [
      { name: "React", icon: "fa-brands fa-react", color: "text-cyan-400" },
      { name: "TypeScript", icon: "fa-brands fa-js", color: "text-blue-400" },
    ],
    status: "In Progress",
    statusColor: "text-cyan-400",
    statusBg: "bg-cyan-500/10 border-cyan-500/20",
    image: "",
    imageLabel: "AlgoTrainer",
    links: [
      { label: "Repository", icon: "fa-brands fa-github" },
    ],
  },
  {
    id: "portfolio",
    name: "Personal Portfolio",
    category: "Frontend Design",
    description: "Portafolio profesional moderno con diseño futurista, glassmorphism, animaciones premium y estética tecnológica. Construido con Astro y TailwindCSS.",
    stack: [
      { name: "Astro", icon: "fa-solid fa-rocket", color: "text-white" },
      { name: "Tailwind", icon: "fa-brands fa-css3-alt", color: "text-blue-400" },
    ],
    status: "Completed",
    statusColor: "text-gray-400",
    statusBg: "bg-white/5 border-white/10",
    image: "",
    imageLabel: "ENGINEER.OS",
    links: [
      { label: "View Source", icon: "fa-brands fa-github" },
    ],
  },
];
---

<section id="section-proyectos" class="relative py-20 md:py-28 overflow-hidden">
  <div class="absolute top-1/4 -right-32 w-96 h-96 bg-blue-500/8 rounded-full blur-3xl"></div>
  <div class="absolute bottom-1/3 -left-32 w-96 h-96 bg-cyan-500/8 rounded-full blur-3xl"></div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="text-center mb-14" data-aos="fade-up">
      <span class="inline-block bg-blue-500/20 text-blue-400 px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider mb-4">
        Proyectos
      </span>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 dark:text-white leading-tight">
        Últimos <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-blue-300 to-cyan-400">Proyectos</span>
      </h2>
    </div>

    <!-- Timeline -->
    <div class="mb-12 md:mb-16 relative" data-aos="fade-up">
      <div class="h-px bg-gray-200 dark:bg-white/10 w-full absolute top-1/2 -translate-y-1/2 rounded-full"></div>
      <div id="timeline-progress" class="h-px bg-gradient-to-r from-blue-500 to-cyan-400 w-0 absolute top-1/2 -translate-y-1/2 rounded-full shadow-[0_0_10px_rgba(6,182,212,0.6)] transition-all duration-500"></div>

      <div class="flex justify-between relative">
        {projects.map((project, i) => (
          <button
            class="timeline-node group flex flex-col items-center gap-3 focus:outline-none cursor-pointer"
            data-target={project.id}
          >
            <div class={`w-4 h-4 rounded-full border-2 transition-all duration-300 group-hover:scale-125 node-indicator ${i === 0 ? "border-cyan-500 shadow-[0_0_15px_rgba(6,182,212,0.8)]" : "border-gray-300 dark:border-white/20"}`}></div>
            <span class={`text-[11px] font-semibold uppercase tracking-wider whitespace-nowrap transition-all duration-300 ${i === 0 ? "text-cyan-400 opacity-100" : "text-gray-500 opacity-50 group-hover:opacity-80"}`}>
              {project.name}
            </span>
          </button>
        ))}
      </div>
    </div>

    <!-- Project Cards -->
    <div class="relative min-h-[420px] md:min-h-[480px]" data-aos="fade-up" data-aos-delay="100">
      {projects.map((project) => (
        <article
          id={project.id}
          class={`project-card w-full rounded-2xl border border-gray-200/60 dark:border-white/10 bg-white dark:bg-white/[0.02] backdrop-blur-xl overflow-hidden transition-all duration-500 ${project.id === "room911" ? "active-card" : "hidden-card"}`}
        >
          <div class="flex flex-col lg:flex-row">
            <!-- Image -->
            <div class="w-full lg:w-1/2 min-h-[250px] md:min-h-[350px] bg-gradient-to-br from-blue-200 via-blue-100 to-cyan-200 dark:from-blue-900/20 dark:via-blue-800/10 dark:to-cyan-900/20 flex items-center justify-center relative overflow-hidden group">
              <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(59,130,246,0.08),transparent_70%)]"></div>
              {project.image ? (
                <img src={project.image} alt={project.name} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
              ) : (
                <div class="text-center z-10">
                  <div class="text-2xl md:text-3xl font-bold text-gray-700 dark:text-white/80 tracking-tight mb-2">{project.imageLabel || project.name}</div>
                  <div class="text-[10px] text-cyan-500/60 tracking-[0.3em] uppercase font-mono">System Active</div>
                </div>
              )}
              <div class="absolute inset-0 bg-gradient-to-t from-white/80 dark:from-[#0a0a0f] via-transparent to-transparent opacity-60 pointer-events-none"></div>
            </div>

            <!-- Content -->
            <div class="w-full lg:w-1/2 p-6 md:p-8 flex flex-col justify-center">
              <div class="flex items-center gap-3 flex-wrap mb-4">
                <span class="px-3 py-1 bg-blue-500/10 text-blue-400 border border-blue-500/20 rounded-full text-[11px] font-bold uppercase tracking-wider">
                  {project.category}
                </span>
                <span class={`px-3 py-1 rounded-full text-[11px] font-semibold flex items-center gap-1.5 border ${project.statusBg} ${project.statusColor}`}>
                  <span class={`w-1.5 h-1.5 rounded-full ${project.status === "Production" ? "bg-emerald-400 animate-ping" : project.status === "In Progress" ? "bg-cyan-400" : "bg-gray-400"}`}></span>
                  {project.status}
                </span>
              </div>

              <h3 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white mb-3">{project.name}</h3>
              <p class="text-gray-500 dark:text-gray-400 text-sm md:text-base leading-relaxed mb-5">
                {project.description}
              </p>

              <div class="flex flex-wrap gap-2 mb-6">
                {project.stack.map((tech) => (
                  <div class="flex items-center gap-1.5 px-3 py-1.5 bg-gray-100 dark:bg-white/[0.03] border border-gray-200 dark:border-white/5 rounded-lg">
                    <i class={`${tech.icon} text-xs ${tech.color}`}></i>
                    <span class="text-[11px] font-medium text-gray-500 dark:text-gray-300">{tech.name}</span>
                  </div>
                ))}
              </div>

              <div class="flex gap-3 flex-wrap">
                {project.links.map((link) => (
                  <a
                    href={link.url || "#"}
                    target={link.url ? "_blank" : undefined}
                    rel={link.url ? "noopener noreferrer" : undefined}
                    class={`inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-[13px] font-semibold transition-all duration-300 ${
                      link.primary
                        ? "bg-gradient-to-r from-blue-600 to-cyan-500 text-white shadow-lg shadow-blue-500/20 hover:shadow-blue-500/40 hover:scale-[1.02]"
                        : "border border-gray-200 dark:border-white/10 text-gray-500 dark:text-gray-300 hover:border-blue-500/40 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-white/[0.03]"
                    }`}
                  >
                    {link.icon && <i class={link.icon}></i>}
                    {link.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Navigation Buttons -->
    <div class="flex items-center justify-center gap-3 mt-8" data-aos="fade-up" data-aos-delay="200">
      <button id="prev-project" class="flex items-center gap-2 px-5 py-2.5 rounded-xl border border-gray-200 dark:border-white/10 text-gray-500 dark:text-gray-300 text-sm font-semibold transition-all duration-300 hover:border-blue-500/40 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-white/[0.03] hover:-translate-x-1">
        <i class="fa-solid fa-arrow-left"></i>
        Anterior
      </button>
      <div class="flex gap-1.5">
        <span id="project-dot-0" class="w-2 h-2 rounded-full bg-cyan-400 transition-all duration-300"></span>
        <span id="project-dot-1" class="w-2 h-2 rounded-full bg-gray-300 dark:bg-white/20 transition-all duration-300"></span>
        <span id="project-dot-2" class="w-2 h-2 rounded-full bg-gray-300 dark:bg-white/20 transition-all duration-300"></span>
        <span id="project-dot-3" class="w-2 h-2 rounded-full bg-gray-300 dark:bg-white/20 transition-all duration-300"></span>
      </div>
      <button id="next-project" class="flex items-center gap-2 px-5 py-2.5 rounded-xl border border-gray-200 dark:border-white/10 text-gray-500 dark:text-gray-300 text-sm font-semibold transition-all duration-300 hover:border-blue-500/40 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-white/[0.03] hover:translate-x-1">
        Siguiente
        <i class="fa-solid fa-arrow-right"></i>
      </button>
    </div>
  </div>
</section>

<style>
  .project-card {
    transition: opacity 0.5s ease-in-out, transform 0.5s ease-in-out;
  }
  .project-card.hidden-card {
    opacity: 0;
    transform: translateY(20px);
    pointer-events: none;
    position: absolute;
    inset: 0;
  }
  .project-card.active-card {
    opacity: 1;
    transform: translateY(0);
    position: relative;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const nodes = document.querySelectorAll('.timeline-node');
    const cards = document.querySelectorAll('.project-card');
    const progressBar = document.getElementById('timeline-progress');
    const prevBtn = document.getElementById('prev-project');
    const nextBtn = document.getElementById('next-project');

    if (!nodes.length || !cards.length || !progressBar) return;

    let currentIndex = 0;

    function goToProject(index) {
      if (index < 0 || index >= nodes.length) return;
      currentIndex = index;

      nodes.forEach((n, i) => {
        const indicator = n.querySelector('.node-indicator');
        const label = n.querySelector('span:last-child');
        const dot = document.getElementById(`project-dot-${i}`);

        if (i === index) {
          indicator?.classList.remove('border-gray-300', 'dark:border-white/20');
          indicator?.classList.add('border-cyan-500', 'shadow-[0_0_15px_rgba(6,182,212,0.8)]');
          label?.classList.remove('text-gray-500', 'opacity-50');
          label?.classList.add('text-cyan-400', 'opacity-100');
          if (dot) { dot.classList.remove('bg-gray-300', 'dark:bg-white/20'); dot.classList.add('bg-cyan-400'); }
        } else {
          indicator?.classList.remove('border-cyan-500', 'shadow-[0_0_15px_rgba(6,182,212,0.8)]');
          indicator?.classList.add('border-gray-300', 'dark:border-white/20');
          label?.classList.remove('text-cyan-400', 'opacity-100');
          label?.classList.add('text-gray-500', 'opacity-50');
          if (dot) { dot.classList.remove('bg-cyan-400'); dot.classList.add('bg-gray-300', 'dark:bg-white/20'); }
        }
      });

      const progress = (index / (nodes.length - 1)) * 100;
      progressBar.style.width = `${progress}%`;

      const targetId = nodes[index].getAttribute('data-target');
      cards.forEach(card => {
        if (card.id === targetId) {
          card.classList.remove('hidden-card');
          card.classList.add('active-card');
        } else {
          card.classList.remove('active-card');
          card.classList.add('hidden-card');
        }
      });
    }

    nodes.forEach((node, index) => {
      node.addEventListener('click', () => goToProject(index));
    });

    if (prevBtn) {
      prevBtn.addEventListener('click', () => goToProject(currentIndex - 1));
    }
    if (nextBtn) {
      nextBtn.addEventListener('click', () => goToProject(currentIndex + 1));
    }
  });
</script>
