---
const navLinks = [
  { href: "#section-portada", label: "Inicio" },
  { href: "#section-experiencia", label: "Experiencia" },
  { href: "#section-proyectos", label: "Proyectos" },
  { href: "#sobre-mi", label: "Sobre mí" },
];
---

<nav class="fixed top-5 left-1/2 -translate-x-1/2 z-50 w-full px-4">
  <div
    class="
      mx-auto
      w-fit
      flex
      items-center
      gap-2
      rounded-full
      border border-gray-200/60 dark:border-white/10
      bg-white/70 dark:bg-black/60
      backdrop-blur-2xl
      px-3
      py-2
      shadow-[0_0_40px_rgba(59,130,246,0.08)]
    "
  >

    <!-- LOGO -->
    <a
      href="#section-portada"
      class="
        hidden md:flex
        items-center
        gap-1
        pr-3
        border-r
        border-gray-200 dark:border-white/10
        text-sm
        font-semibold
        text-gray-800 dark:text-white
        tracking-wide
      "
    >
      <span class="text-blue-400">&lt;</span>
      Emerson
      <span class="text-cyan-400">/&gt;</span>
    </a>

    <!-- DESKTOP NAV -->
    <div class="hidden md:flex items-center gap-1">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="
            group
            relative
            px-4
            py-2
            text-sm
            text-gray-500 dark:text-gray-300
            transition-all
            duration-300
            hover:text-gray-900 dark:hover:text-white
          "
        >
          <span class="relative z-10">{link.label}</span>

          <!-- Hover Background -->
          <span
            class="
              absolute
              inset-0
              rounded-full
              bg-gray-900/[0.04] dark:bg-white/[0.04]
              opacity-0
              transition-all
              duration-300
              group-hover:opacity-100
            "
          ></span>

          <!-- Glow Line -->
          <span
            class="
              absolute
              bottom-0
              left-1/2
              h-[2px]
              w-0
              -translate-x-1/2
              rounded-full
              bg-gradient-to-r
              from-blue-500
              to-cyan-400
              transition-all
              duration-300
              group-hover:w-3/4
            "
          ></span>
        </a>
      ))}
    </div>

    <!-- RIGHT ACTIONS -->
    <div class="hidden md:flex items-center gap-2 pl-2 border-l border-gray-200 dark:border-white/10">

      <!-- LANGUAGE -->
      <button
        class="
          flex
          items-center
          gap-2
          rounded-full
          px-3
          py-2
          text-sm
          text-gray-500 dark:text-gray-300
          hover:bg-gray-900/[0.04] dark:hover:bg-white/[0.05]
          hover:text-gray-900 dark:hover:text-white
          transition-all
        "
      >
        🇨🇴 Español
      </button>

      <!-- STATUS -->
      <div
        class="
          flex
          items-center
          gap-2
          rounded-full
          border
          border-emerald-500/20
          bg-emerald-500/10
          px-3
          py-2
          text-xs
          font-medium
          text-emerald-400
        "
      >
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-400"></span>
        </span>

        Disponible
      </div>

      <!-- DOWNLOAD CV -->
      <a
        href="/cv_emerson_reyes.html"
        download
        class="
          flex
          items-center
          gap-2
          rounded-full
          bg-gradient-to-r
          from-blue-600
          to-cyan-500
          px-4
          py-2
          text-sm
          font-semibold
          text-white
          transition-all
          duration-300
          hover:scale-105
          hover:shadow-lg
          hover:shadow-blue-500/25
        "
      >
        <i class="fa-solid fa-download"></i>
        Descargar CV
      </a>

      <!-- THEME TOGGLE -->
      <button id="theme-toggle"
        class="
          flex
          items-center
          justify-center
          w-9
          h-9
          rounded-full
          text-gray-500 dark:text-gray-300
          hover:bg-gray-900/[0.04] dark:hover:bg-white/[0.05]
          hover:text-gray-900 dark:hover:text-white
          transition-all
        "
        aria-label="Cambiar tema"
      >
        <i id="theme-icon" class="fa-solid fa-moon text-sm"></i>
      </button>
    </div>

    <!-- MOBILE BUTTON -->
    <button
      id="menu-toggle"
      class="
        md:hidden
        flex
        items-center
        justify-center
        w-10
        h-10
        rounded-full
        text-gray-700 dark:text-white
        hover:bg-gray-900/5 dark:hover:bg-white/5
        transition-all
      "
    >
      <i id="menu-icon" class="fa-solid fa-bars text-lg"></i>
    </button>
  </div>

  <!-- MOBILE MENU -->
  <div
    id="mobile-menu"
    class="
      hidden
      md:hidden
      mt-3
      rounded-3xl
      border
      border-gray-200/60 dark:border-white/10
      bg-white/90 dark:bg-black/80
      backdrop-blur-2xl
      p-4
      shadow-2xl
    "
  >
    <div class="flex flex-col gap-2">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="
            rounded-xl
            px-4
            py-3
            text-sm
            text-gray-500 dark:text-gray-300
            transition-all
            duration-300
            hover:bg-gray-900/[0.04] dark:hover:bg-white/[0.04]
            hover:text-gray-900 dark:hover:text-white
          "
        >
          {link.label}
        </a>
      ))}

    

      <a
        href="#contacto"
        class="
          rounded-xl
          bg-gradient-to-r
          from-blue-600
          to-cyan-500
          px-4
          py-3
          text-center
          text-sm
          font-semibold
          text-white
          transition-all
          duration-300
          hover:scale-[1.02]
        "
      >
        Contactar
      </a>

      <a
        href="/cv_emerson_reyes.html"
        download
        class="
          rounded-xl
          border
          border-gray-200/60 dark:border-white/10
          bg-gray-100/50 dark:bg-white/[0.03]
          px-4
          py-3
          text-center
          text-sm
          font-semibold
          text-gray-700 dark:text-white
          transition-all
          duration-300
          hover:bg-gray-200/50 dark:hover:bg-white/[0.08]
        "
      >
        <i class="fa-solid fa-download"></i>
        Descargar CV
      </a>

      <button
        id="theme-toggle-mobile"
        class="
          rounded-xl
          border
          border-gray-200/60 dark:border-white/10
          bg-gray-100/50 dark:bg-white/[0.03]
          px-4
          py-3
          text-center
          text-sm
          font-semibold
          text-gray-500 dark:text-gray-300
          transition-all
          duration-300
          hover:bg-gray-200/50 dark:hover:bg-white/[0.08]
          hover:text-gray-900 dark:hover:text-white
        "
      >
        <i id="theme-icon-mobile" class="fa-solid fa-moon"></i>
        <span class="ml-2">Modo oscuro</span>
      </button>
    </div>
  </div>
</nav>

<script>
  const menuToggle = document.getElementById("menu-toggle");
  const menuIcon = document.getElementById("menu-icon");
  const mobileMenu = document.getElementById("mobile-menu");

  if (menuToggle && menuIcon && mobileMenu) {
    menuToggle.addEventListener("click", () => {
      mobileMenu.classList.toggle("hidden");

      menuIcon.classList.toggle("fa-bars");
      menuIcon.classList.toggle("fa-times");
    });

    mobileMenu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        mobileMenu.classList.add("hidden");

        menuIcon.classList.add("fa-bars");
        menuIcon.classList.remove("fa-times");
      });
    });
  }

  const themeIcon = document.getElementById("theme-icon");
  const themeIconMobile = document.getElementById("theme-icon-mobile");
  const themeToggleMobile = document.getElementById("theme-toggle-mobile");
  const themeToggle = document.getElementById("theme-toggle");

  function updateUI(isDark) {
    const iconClass = isDark ? "fa-sun" : "fa-moon";
    const text = isDark ? "Modo claro" : "Modo oscuro";

    if (themeIcon) {
      themeIcon.className = `fa-solid ${iconClass} text-sm`;
    }
    if (themeIconMobile) {
      themeIconMobile.className = `fa-solid ${iconClass}`;
    }
    if (themeToggleMobile) {
      const span = themeToggleMobile.querySelector("span");
      if (span) span.textContent = text;
    }
  }

  function toggleTheme(event) {
    const x = event.clientX;
    const y = event.clientY;

    const endRadius = Math.hypot(
      Math.max(x, innerWidth - x),
      Math.max(y, innerHeight - y)
    );

    if (!document.startViewTransition) {
      document.documentElement.classList.toggle("dark");
      const isDark = document.documentElement.classList.contains("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
      updateUI(isDark);
      return;
    }

    const transition = document.startViewTransition(() => {
      document.documentElement.classList.toggle("dark");
      const isDark = document.documentElement.classList.contains("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
      updateUI(isDark);
    });

    transition.ready.then(() => {
      document.documentElement.animate(
        {
          clipPath: [
            `circle(0px at ${x}px ${y}px)`,
            `circle(${endRadius}px at ${x}px ${y}px)`
          ]
        },
        {
          duration: 700,
          easing: "ease-in-out",
          pseudoElement: "::view-transition-new(root)"
        }
      );
    });
  }

  if (themeToggle) {
    themeToggle.addEventListener("click", toggleTheme);
  }
  if (themeToggleMobile) {
    themeToggleMobile.addEventListener("click", toggleTheme);
  }

  updateUI(document.documentElement.classList.contains("dark"));
</script>