---
---
<section id="section-portada" class="relative pb-16 lg:pb-32">
  <div class="container mx-auto px-4 pt-8">
    <div class="fondo text-center p-4 md:p-8 border border-blue-500/30 rounded-[2.5rem] shadow-2xl relative overflow-visible">
      <p class="text-blue-400 text-xl md:text-2xl font-medium mb-1 animate__animated animate__fadeIn">- Hola</p>
      <h2 class="text-3xl md:text-5xl xl:text-6xl font-bold text-white leading-tight mb-8">
        Soy <span class="text-blue-400">Emerson</span> <br />
        UX/UI Designer
      </h2>
      
      <!-- Central Flex Area -->
      <div class="flex flex-col lg:flex-row justify-center items-center gap-8 lg:gap-16 xl:gap-24 mb-16">
        
        <!-- Left Column: Quote (Desktop only) -->
        <div class="hidden lg:block text-left max-w-[220px] text-white/90">
          <i class="fa-solid fa-quote-left text-blue-400 text-3xl mb-2"></i>
          <p class="font-semibold italic text-base leading-relaxed">
            Construir sin entender es levantar castillos en el aire.
          </p>
        </div>
        
        <!-- Center Column: Avatar Circle -->
        <div class="relative">
          <div class="w-[280px] h-[280px] sm:w-[320px] sm:h-[320px] md:w-[380px] md:h-[380px] rounded-full bg-blue-600/35 border-2 border-blue-400/20 relative flex items-end justify-center overflow-visible shadow-lg">
            <!-- Floating Buttons inside circle bottom -->
            <div class="absolute -bottom-4 left-1/2 -translate-x-1/2 flex gap-2 bg-white p-1.5 rounded-2xl shadow-xl z-20 w-max border border-gray-100">
              <a href="https://github.com/152004E?tab=repositories" target="_blank" class="bg-blue-600 hover:bg-blue-700 text-white text-xs sm:text-sm font-semibold py-2 px-4 rounded-xl flex items-center gap-1.5 transition duration-300 shadow-md">
                Proyectos <i class="fa-regular fa-folder-open text-xs"></i>
              </a>
              <a href="#contacto" class="border border-blue-500 text-blue-600 hover:bg-blue-50 text-xs sm:text-sm font-semibold py-2 px-4 rounded-xl flex items-center gap-1.5 transition duration-300">
                Contáctame <i class="fa-solid fa-envelope text-xs"></i>
              </a>
            </div>
            <!-- Avatar Image -->
            <img class="w-[220px] sm:w-[250px] md:w-[300px] object-contain rounded-b-full z-10" src="/images/imagenparagithudoptimazadaOP.png" alt="Emerson Reyes" />
          </div>
        </div>
        
        <!-- Right Column: Social Links (Desktop only) -->
        <div class="hidden lg:block text-left text-white/95">
          <p class="font-bold text-lg mb-3">Sígueme en:</p>
          <div class="flex items-center gap-3 text-2xl">
            <a href="https://www.facebook.com/luisfavian.avila/" target="_blank" class="text-blue-500 hover:text-blue-400 transition duration-300">
              <i class="fa-brands fa-facebook"></i>
            </a>
            <a href="https://www.instagram.com/emerson_15a/" target="_blank" class="text-pink-500 hover:text-pink-400 transition duration-300">
              <i class="fa-brands fa-instagram"></i>
            </a>
            <a href="https://github.com/152004E" target="_blank" class="text-white hover:text-gray-300 transition duration-300">
              <i class="fa-brands fa-github"></i>
            </a>
          </div>
        </div>
      </div>

      <!-- Experience Section (Absolutely positioned on large screens, flows below on small screens) -->
      <div class="relative lg:absolute lg:left-1/2 lg:-translate-x-1/2 lg:-bottom-20 w-full lg:w-[90%] xl:w-[1100px] z-30 mt-8 lg:mt-0 animate__animated animate__fadeInUp animate__delay-1s">
        <div class="bg-zinc-950/95 border border-zinc-800 p-5 md:p-6 rounded-[2rem] shadow-2xl">
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
            <div class="bg-blue-600 hover:scale-[1.03] p-4 md:p-5 rounded-2xl text-left text-white transition duration-300 shadow-md">
              <h3 class="text-3xl md:text-4xl font-extrabold mb-1">15+</h3>
              <p class="text-sm text-blue-100 font-medium leading-snug">
                Proyectos desarrollados para clientes locales y startups digitales
              </p>
            </div>
            <div class="bg-zinc-900/80 hover:scale-[1.03] p-4 md:p-5 rounded-2xl text-left border border-white/5 transition duration-300">
              <h3 class="text-3xl md:text-4xl font-extrabold text-blue-400 mb-1">3</h3>
              <p class="text-sm text-gray-400 font-medium leading-snug">
                Años de experiencia en diseño y desarrollo web
              </p>
            </div>
            <div class="bg-zinc-900/80 hover:scale-[1.03] p-4 md:p-5 rounded-2xl text-left border border-white/5 transition duration-300">
              <h3 class="text-3xl md:text-4xl font-extrabold text-blue-400 mb-1">6</h3>
              <p class="text-sm text-gray-400 font-medium leading-snug">
                Proyectos integrando frontend, backend y bases de datos
              </p>
            </div>
            <div class="bg-zinc-900/80 hover:scale-[1.03] p-4 md:p-5 rounded-2xl text-left border border-white/5 transition duration-300">
              <h3 class="text-3xl md:text-4xl font-extrabold text-blue-400 mb-1">2+</h3>
              <p class="text-sm text-gray-400 font-medium leading-snug">
                Aplicaciones diseñadas con enfoque en usabilidad y rendimiento.
              </p>
            </div>
          </div>
        </div>
      </div>
      
    </div>
  </div>
</section>
