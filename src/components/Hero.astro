---
import Button from './Button.astro';
import ProfileCard from './ProfileCard.astro';
import SocialLinks from './SocialLinks.astro';
import StatsGrid from './StatsGrid.astro';
---

<section id="section-portada" class="relative min-h-screen flex items-center pt-24 pb-16 lg:pb-32 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-[#0a0a0f] via-[#0d1117] to-[#0a0a0f]"></div>
  <div
    class="absolute inset-0"
    style="background-image: linear-gradient(rgba(59,130,246,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(59,130,246,0.03) 1px, transparent 1px); background-size: 60px 60px;"
  ></div>
  <div class="absolute top-1/4 -left-32 w-96 h-96 bg-blue-500/10 rounded-full blur-3xl"></div>
  <div class="absolute bottom-1/4 -right-32 w-96 h-96 bg-cyan-500/10 rounded-full blur-3xl"></div>
  <div class="absolute inset-0 bg-[url(/images/portada-fondoOP.png)] bg-cover bg-center opacity-5"></div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16 xl:gap-24">
      <div class="flex-1 text-center lg:text-left">
        <p class="text-blue-400 text-lg md:text-xl font-mono font-medium mb-2 tracking-wider animate__animated animate__fadeIn">
          &lt;Hola, soy&gt;
        </p>
        <h1 class="text-4xl sm:text-5xl md:text-6xl xl:text-7xl font-bold text-white leading-tight mb-4 animate__animated animate__fadeIn animate__delay-1s">
          Emerson <br class="hidden sm:block" />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-blue-300 to-cyan-400">
            Reyes
          </span>
        </h1>
        <p class="text-lg sm:text-xl md:text-2xl text-gray-400 mb-6 font-light animate__animated animate__fadeIn animate__delay-2s">
          Desarrollador de Software <span class="text-blue-400">|</span> UX/UI Designer
        </p>
        <div class="hidden lg:block mb-8 animate__animated animate__fadeIn animate__delay-2s">
          <div class="flex items-start gap-3">
            <i class="fa-solid fa-quote-left text-blue-400/50 text-2xl mt-1"></i>
            <p class="text-gray-500 italic text-base leading-relaxed border-l-2 border-blue-500/30 pl-4">
              "Construir sin entender es levantar castillos en el aire."
            </p>
          </div>
        </div>
        <div class="flex flex-wrap gap-4 justify-center lg:justify-start mb-8 animate__animated animate__fadeIn animate__delay-3s">
          <Button
            to="https://github.com/152004E?tab=repositories"
            target="_blank"
            text="Ver Proyectos"
            iconRight="fa-regular fa-folder-open"
            className="shadow-lg shadow-blue-500/20"
          />
          <Button
            to="#contacto"
            text="Contáctame"
            iconRight="fa-solid fa-envelope"
            variant="secondary"
            className="border-blue-500/30 hover:bg-blue-500/10"
          />
        </div>
      </div>
      <div class="flex-shrink-0 flex flex-col items-center animate__animated animate__fadeIn animate__delay-2s">
        <ProfileCard />
        <div class="mt-6 animate__animated animate__fadeIn animate__delay-3s">
          <p class="text-sm text-gray-500 font-medium mb-3 text-center">Sígueme en:</p>
          <div class="flex justify-center">
            <SocialLinks />
          </div>
        </div>
      </div>
    </div>
    <div class="animate__animated animate__fadeInUp animate__delay-1s">
      <StatsGrid />
    </div>
  </div>
</section>
