---
const email = "reyesemerson643@gmail.com";
const phoneNumber = "573222463385";
const githubUrl = "https://github.com/152004E";
const linkedinUrl = "https://www.linkedin.com/in/emerson-reyes-97920a386";
const whatsappMessage = "¡Hola! Me gustaría saber más sobre tus servicios.";
const whatsappUrl = `https://wa.me/${phoneNumber}?text=${encodeURIComponent(whatsappMessage)}`;
---

<section id="contacto" class="relative py-20 md:py-28 overflow-hidden">
  <div class="absolute top-1/3 left-1/4 w-96 h-96 bg-blue-500/10 rounded-full blur-3xl"></div>
  <div class="absolute bottom-1/3 right-1/4 w-96 h-96 bg-cyan-500/10 rounded-full blur-3xl"></div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="mx-auto max-w-4xl" data-aos="fade-up">
      <div class="relative overflow-hidden rounded-3xl border border-white/10 bg-black/40 backdrop-blur-2xl p-8 md:p-12 text-center shadow-[0_24px_80px_rgba(0,0,0,0.4)]">
        <div class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(circle_at_top,rgba(59,130,246,0.08),transparent_45%),radial-gradient(circle_at_bottom_right,rgba(6,182,212,0.06),transparent_35%)]"></div>

        <span class="inline-block bg-blue-500/20 text-blue-400 px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider mb-6">
          Contacto
        </span>

        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white leading-tight mb-4">
          Hablemos de tu<br class="sm:hidden" />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-blue-300 to-cyan-400">
            próximo proyecto
          </span>
        </h2>

        <p class="mx-auto max-w-2xl text-gray-400 text-sm md:text-base leading-relaxed mb-8">
          Ya sea desarrollo frontend, backend, automatización, IA, o construir sistemas escalables —
          estoy abierto a nuevas oportunidades y desafíos tecnológicos.
          Conversemos y hagamos algo increíble juntos.
        </p>

        <div class="flex items-center justify-center gap-3 md:gap-4">
          <a
            href={`mailto:${email}`}
            aria-label="Enviar correo"
            class="flex h-11 w-11 md:h-12 md:w-12 items-center justify-center rounded-full border border-white/10 bg-white/5 text-blue-400 transition-all duration-300 hover:-translate-y-1 hover:border-blue-500/40 hover:bg-blue-500/10 hover:shadow-[0_0_20px_rgba(59,130,246,0.25)]"
          >
            <i class="fa-solid fa-envelope text-lg"></i>
          </a>

          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Contactar por WhatsApp"
            class="flex h-11 w-11 md:h-12 md:w-12 items-center justify-center rounded-full border border-white/10 bg-white/5 text-green-400 transition-all duration-300 hover:-translate-y-1 hover:border-green-500/40 hover:bg-green-500/10 hover:shadow-[0_0_20px_rgba(34,197,94,0.25)]"
          >
            <i class="fa-brands fa-whatsapp text-lg"></i>
          </a>

          <a
            href={githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Abrir perfil de GitHub"
            class="flex h-11 w-11 md:h-12 md:w-12 items-center justify-center rounded-full border border-white/10 bg-white/5 text-white transition-all duration-300 hover:-translate-y-1 hover:border-white/40 hover:bg-white/10 hover:shadow-[0_0_20px_rgba(255,255,255,0.15)]"
          >
            <i class="fa-brands fa-github text-lg"></i>
          </a>

          <a
            href={linkedinUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Abrir perfil de LinkedIn"
            class="flex h-11 w-11 md:h-12 md:w-12 items-center justify-center rounded-full border border-white/10 bg-white/5 text-blue-300 transition-all duration-300 hover:-translate-y-1 hover:border-blue-400/40 hover:bg-blue-400/10 hover:shadow-[0_0_20px_rgba(96,165,250,0.25)]"
          >
            <i class="fa-brands fa-linkedin-in text-lg"></i>
          </a>
        </div>

        <p class="mt-8 text-xs text-gray-600">
          Respuesta en menos de 24 horas ⚡
        </p>
      </div>
    </div>
  </div>
</section>
