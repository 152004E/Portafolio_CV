---
import Button from './Button.astro';
---
<section id="sobre-mi" class="container mx-auto px-4 flex justify-center pt-24 md:pt-36">
  <div
    class="blur-bg border border-white/10 p-6 md:p-8 rounded-3xl text-center max-w-[700px] w-full shadow-xl"
    data-aos="fade-right"
  >
    <div class="flex flex-col items-center">
      <span class="bg-blue-500/20 text-blue-400 px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider">
        Descripción
      </span>
      <h3 class="text-blue-400 font-bold text-2xl md:text-3xl mt-4">
        Emerson Fabian Reyes Arias.
      </h3>
      <p class="text-gray-300 mt-4 text-base md:text-lg leading-relaxed max-w-[600px]">
        Tecnólogo en Análisis y Desarrollo de Software, con más de 3 años de experiencia desarrollando proyectos de forma autónoma y experiencia práctica en la Fábrica de Software del SENA. Con conocimientos sólidos en desarrollo Full Stack utilizando tecnologías como Java, Spring Boot, JavaScript, React, TypeScript y Node.js.
      </p>
      <p class="text-gray-400 mt-3 text-sm md:text-base leading-relaxed max-w-[600px]">
        Experiencia en construcción de interfaces web modernas y responsivas con Tailwind CSS.
      </p>
      <Button
        to="https://github.com/152004E"
        target="_blank"
        text="Ver en GitHub"
        iconRight="fa-brands fa-github"
        className="mt-6"
      />
    </div>
  </div>
</section>
<div class="container mx-auto my-12 border-b border-blue-500/10 max-w-[1200px]"></div>
